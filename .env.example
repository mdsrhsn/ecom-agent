# ── AI agent ──────────────────────────────────────────────
# The chat agent runs on Google Gemini (gemini-2.5-flash-lite).
# Get a free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional — only needed if you switch the agent back to Anthropic Claude.
ANTHROPIC_API_KEY=

# ── Shopify (Women Comforts store) ────────────────────────
SHOPIFY_STORE_URL=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_...
SHOPIFY_WEBHOOK_SECRET=

# ── Courier APIs ──────────────────────────────────────────
POSTEX_API_KEY=
POSTEX_BASE_URL=https://api.postex.pk/services/integration/api/order/v1

DAEWOO_API_KEY=
DAEWOO_BASE_URL=

DIGIDOKAAN_API_KEY=
DIGIDOKAAN_BASE_URL=

# ── WhatsApp Cloud API (Meta) ─────────────────────────────
WHATSAPP_PHONE_ID=
WHATSAPP_ACCESS_TOKEN=

# ── Email (SMTP) ──────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── Notification recipients (intl format, e.g. 923001234567) ──
OWNER_PHONE=
TEAM_PHONES=
OWNER_EMAIL=
TEAM_EMAILS=

# ── Database (Railway auto-sets this in production) ───────
DATABASE_URL=sqlite:///./dev.db

# ── Access control ────────────────────────────────────────
# Protects the dashboard + /agent/chat. Set a real secret in production —
# then open the dashboard as  https://your-app/?key=YOUR_SECRET
# Leave as "change-me" for local dev to disable the key check.
APP_SECRET=change-me

TIMEZONE=Asia/Karachi
